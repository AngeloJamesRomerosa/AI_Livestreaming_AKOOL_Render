# Option A: API key (simplest)
AKOOL_API_KEY=your_api_key_here

# Option B: Client credentials
# AKOOL_CLIENT_ID=your_client_id_here
# AKOOL_CLIENT_SECRET=your_client_secret_here

PORT=8000

# Public URL online
PUBLIC_BASE_URL=URL

# Required for uploaded images to work with AKOOL.
# AKOOL's servers fetch the source face image from this URL, so localhost won't work.
# Run:  ngrok http 8000
# Then set this to the https URL ngrok gives you, e.g.:
# PUBLIC_BASE_URL=https://abc123.ngrok-free.app
